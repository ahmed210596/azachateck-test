<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_monitor_search_dashboard" model="ir.ui.view">
        <field name="name">partner.monitor.search.dashboard</field>
        <field name="model">azk_odoo_partner_monitor.partner</field>
        <field name="arch" type="xml">
            <search>
                <field name="current_status" />
                <field name="country_id" />
                <field name="year_first_seen" />
                <filter string="Gold" name="gold" domain="[('current_status','=','gold')]" />
                <filter string="Silver" name="silver" domain="[('current_status','=','silver')]" />
                <filter string="Ready" name="ready" domain="[('current_status','=','ready')]" />
                <group expand="0" string="Group By">
                    <filter string="Country" name="group_country"
                        context="{'group_by':'country_id'}" />
                    <filter string="Status" name="group_status"
                        context="{'group_by':'current_status'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="view_graph_active_partners" model="ir.ui.view">
        <field name="name">partner.monitor.graph.active</field>
        <field name="model">azk_odoo_partner_monitor.partner</field>
        <field name="arch" type="xml">
            <graph string="Active Partners" type="bar" stacked="1">
                <field name="country_id" />
                <field name="current_status" />
            </graph>
        </field>
    </record>

    <record id="view_graph_project_size" model="ir.ui.view">
        <field name="name">partner.monitor.graph.project</field>
        <field name="model">azk_odoo_partner_monitor.partner</field>
        <field name="arch" type="xml">
            <graph string="Project Size Distribution" type="bar" stacked="1">
                <field name="country_id" />
                <field name="project_size_bucket" />
            </graph>
        </field>
    </record>

    <record id="action_top_5_active" model="ir.actions.act_window">
        <field name="name">Top 5 Countries (Active Partners)</field>
        <field name="res_model">azk_odoo_partner_monitor.partner</field>
        <field name="view_mode">graph</field>
        <field name="domain">[('is_top_5_country', '=', True)]</field>
        <field name="view_id" ref="view_graph_active_partners" />
        <field name="context">{'search_default_group_country': 1, 'search_default_group_status': 1}</field>
    </record>

    <record id="action_bottom_5_active" model="ir.actions.act_window">
        <field name="name">Bottom 5 Countries (Active Partners)</field>
        <field name="res_model">azk_odoo_partner_monitor.partner</field>
        <field name="view_mode">graph</field>
        <field name="domain">[('is_bottom_5_country', '=', True)]</field>
        <field name="view_id" ref="view_graph_active_partners" />
        <field name="context">{'search_default_group_country': 1, 'search_default_group_status': 1}</field>
    </record>

    <record id="action_top_5_project" model="ir.actions.act_window">
        <field name="name">Top 5 Countries (Project Size)</field>
        <field name="res_model">azk_odoo_partner_monitor.partner</field>
        <field name="view_mode">graph</field>
        <field name="domain">[('is_top_5_country', '=', True)]</field>
        <field name="view_id" ref="view_graph_project_size" />
        <field name="context">{'search_default_group_country': 1}</field>
    </record>

    <record id="action_bottom_5_project" model="ir.actions.act_window">
        <field name="name">Bottom 5 Countries (Project Size)</field>
        <field name="res_model">azk_odoo_partner_monitor.partner</field>
        <field name="view_mode">graph</field>
        <field name="domain">[('is_bottom_5_country', '=', True)]</field>
        <field name="view_id" ref="view_graph_project_size" />
        <field name="context">{'search_default_group_country': 1}</field>
    </record>

    <record id="view_partner_monitor_dashboard" model="ir.ui.view">
        <field name="name">Partner Monitor Dashboard</field>
        <field name="model">board.board</field>
        <field name="arch" type="xml">
            <form string="Partner Monitor Dashboard">
                <board style="1-1">
                    <column>
                        <action name="%(action_top_5_active)d" string="Top 5 Active Countries" />
                        <action name="%(action_bottom_5_active)d" string="Bottom 5 Active Countries" />
                    </column>
                    <column>
                        <action name="%(action_top_5_project)d" string="Top 5 Project Sizes" />
                        <action name="%(action_bottom_5_project)d" string="Bottom 5 Project Sizes" />
                    </column>
                </board>
            </form>
        </field>
    </record>

    <record id="open_partner_monitor_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">board.board</field>
        <field name="view_mode">form</field>
        <field name="usage">menu</field>


    </record>

    <menuitem id="menu_dashboard_main" name="Dashboard" parent="menu_partner_monitor_root"
        sequence="1" action="open_partner_monitor_dashboard" />

</odoo>