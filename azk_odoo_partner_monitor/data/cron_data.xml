<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_scrape_odoo_partners" model="ir.cron">
            <field name="name">Odoo Partner Monitor: Scrape Every 5 Minutes</field>
            <field name="model_id" ref="model_azk_odoo_partner_monitor_scraper" />
            <field name="state">code</field>
            <field name="code">model.run_daily_scrape()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True" />
            <field name="nextcall" eval="datetime.now() + timedelta(minutes=5)" />
        </record>
    </data>
</odoo>